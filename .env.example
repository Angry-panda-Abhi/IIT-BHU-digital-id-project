# College ID System Configuration
# Copy this file to .env and fill in your actual credentials

# --- Flask Core ---
SECRET_KEY=dev-secret-key-change-in-production-2026
HMAC_SECRET=hmac-secret-key-change-in-production

# --- Database ---
# DATABASE_URL=postgres://user:password@host:port/dbname

# --- Email Configuration (Gmail SMTP) ---
# Set MAIL_SUPPRESS_SEND to false to actually send emails
MAIL_SUPPRESS_SEND=false
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
# Your full Gmail address (e.g. admin@gmail.com)
MAIL_USERNAME=motapanda777@gmail.com
# Use an App Password if 2FA is enabled on your Google account
MAIL_PASSWORD=kaushal@1234
MAIL_DEFAULT_SENDER=noreply@itbhu.ac.in

# --- Cloud Storage (Optional) ---
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# --- Google OAuth Credentials (REQUIRED for Student Portal) ---
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
